.planning/research/.cache/
# refs/ holds fetched COPYRIGHTED reference artifacts (FORCE .xls, AV PDFs) —
# never commit them (Pitfall 7). Only the fetch script + SHA-256 manifest are tracked.
refs/*
!refs/fetch.sh
!refs/refs.sha256
target/

# Python oracle bytecode cache (tools/nord2000_oracle)
__pycache__/
*.pyc

# User project data (envi-service ProjectStore root) — never repo content
# (06-RESEARCH Open Q2). The ENVI_PROJECTS_DIR override points elsewhere in prod.
projects/

# Frontend (web/) build/test noise. web/dist STAYS TRACKED — it is the shipped
# artifact served from disk by envi-service (ServeDir(web/dist), SVC-03); the
# static-bundle contract test + repo_web_dist() both require it. Only the
# node_modules install tree and the Playwright run artifacts are ignored.
web/node_modules/
web/test-results/
web/playwright-report/

# wasm-bindgen build output (envi-gis-wasm → JS glue + .wasm), regenerated by
# `npm run build:wasm` from the committed Rust crate. Treated as a build artifact
# (like the compiled bundle inside web/dist): NOT tracked here. The type contract
# that DOES need tracking — the ts-rs-generated web/src/generated/wire.ts — is a
# specific committed file with its own no-drift test, unaffected by this ignore.
web/src/generated/wasm/

# Threaded wasm-bindgen build output (envi-compute-wasm → JS glue + .wasm +
# rayon worker snippets), regenerated by `npm run build:wasm:compute` (nightly +
# -Zbuild-std + atomics, plan 10-03). Same build-artifact treatment as the gis
# module above; the committed wire.ts type contract is unaffected.
web/src/generated/wasm-compute/
