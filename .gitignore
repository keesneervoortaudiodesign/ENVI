.planning/research/.cache/
# refs/ holds fetched COPYRIGHTED reference artifacts (FORCE .xls, AV PDFs) —
# never commit them (Pitfall 7). Only the fetch script + SHA-256 manifest are tracked.
refs/*
!refs/fetch.sh
!refs/refs.sha256
target/

# Python oracle bytecode cache (tools/nord2000_oracle)
__pycache__/
*.pyc

# User project data (envi-service ProjectStore root) — never repo content
# (06-RESEARCH Open Q2). The ENVI_PROJECTS_DIR override points elsewhere in prod.
projects/
